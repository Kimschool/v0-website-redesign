# Copy to .env and fill in values. Used by send.php (project root, PHPMailer) and public/mail/send.php (mail()).

# --- Required for root send.php (SMTP) ---
SMTP_USER=
SMTP_PASS=
MAIL_TO=

# --- SMTP (optional defaults) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_FROM=info@kcp.ac.jp
SMTP_FROM_NAME=KCP Website

# --- Optional ---
# Comma-separated CC addresses
MAIL_CC=
# When the form has no valid applicant email, Reply-To on staff notification uses this (default: SMTP_FROM)
MAIL_REPLY_FALLBACK=
MAIL_SUBJECT_PREFIX=【KCP】証明書発行申込み
MAIL_AUTOREPLY_SUBJECT=【KCP】申請ありがとうございます

# --- public/mail/send.php only (overrides SMTP_FROM* if set) ---
# MAIL_FROM_EMAIL=
# MAIL_FROM_NAME=

# --- Next.js: お知らせ ---
# お知らせはさくら側の PHP（/news/list.php ・ article.php）またはリポジトリ内の静的ページを利用します。
# JSON API は廃止しました。
