# Copy to .env and fill in values.
# Root send.php: PHPMailer SMTP (requires SMTP_USER/SMTP_PASS).
# out/mail/send.php: same SMTP when SMTP_USER/SMTP_PASS + vendor/autoload.php exist; otherwise PHP mail().

# --- Required for root send.php (SMTP) ---
SMTP_USER=
SMTP_PASS=
MAIL_TO=

# --- SMTP (optional defaults) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_FROM=info@kcp.ac.jp
SMTP_FROM_NAME=KCP Website

# --- Optional ---
# out/mail/send.php CORS（別オリジンから fetch する場合）。本番のみ許可するなら https://www.kcp.ac.jp
# MAIL_CORS_ORIGIN=https://www.kcp.ac.jp
# Comma-separated CC addresses
MAIL_CC=
# When the form has no valid applicant email, Reply-To on staff notification uses this (default: SMTP_FROM)
MAIL_REPLY_FALLBACK=
MAIL_SUBJECT_PREFIX=【KCP】証明書発行申込み
# 申請者へ送る自動返信の件名（public/mail/send.php の mail() 経路でも使用）
MAIL_AUTOREPLY_SUBJECT=【KCP】申請ありがとうございます
# public/mail/send.php (PHP 5.6 mail): 送信拒否時のみ。ドメインで許可された From メール
# MAIL_ENVELOPE_FROM=info@kcp.ac.jp
# HTMLメールの副題・フッター（空なら日本語デフォルト）
# MAIL_HTML_SUBTITLE=
# MAIL_HTML_FOOTER=

# --- public/mail/send.php only (overrides SMTP_FROM* if set) ---
# MAIL_FROM_EMAIL=
# MAIL_FROM_NAME=

# --- Next.js: お知らせ（任意）---
# 未設定でも本番では自動で {オリジン}/news/api/posts.php を fetch（再ビルド不要）
# プレビュー・別ホストから本番 API を読むときだけ設定
# NEXT_PUBLIC_NEWS_API_URL=https://www.kcp.ac.jp/news/api/posts.php
